{% extends 'base.html.twig' %}

{% block localstyle %}
    <style>
        body {
            background-color: transparent;
        }
    </style>
{% endblock %}

{% block body %}
    <a class="btn btn-secondary" onClick="closeModal();">Annuler</a>
    <form action="{{ path('bninefiles_files_uploadfile', {
        domain: domain,
        id: id,
        path: path
    }) }}"
    class="dropzone" id="myDropzone" style="margin-top:10px"></form>
{% endblock %}

{% block localscript %}
    <script>
        Dropzone.options.myDropzone = {
            paramName: "{{endpoint}}",
            maxFilesize: 20,
            parallelUploads: 5,
            uploadMultiple: false,
            {% if imageOnly is defined and imageOnly %}
            acceptedFiles: ".jpg,.jpeg,.png,.gif,.webp,.svg,.bmp,.tiff,.tif",
            dictDefaultMessage: "Déposez vos images ici pour les téléverser",
            {% else %}
            dictDefaultMessage: "Déposez vos fichiers ici pour les téléverser",
            {% endif %}
            successmultiple: function (files, response) {
                console.log("multi uploaded", files);
            },
            queuecomplete: function () {
                window.parent.$("#mymodalupload-{{ domain }}-{{ id|e('html_attr') }}").modal('hide');
                if (typeof window.parent.refreshFileBrowser === 'function') {
                    window.parent.refreshFileBrowser();
                }
            }
        };

        function closeModal() {
            window.parent.$("#mymodal").modal('hide');
        }
    </script>
{% endblock %}
